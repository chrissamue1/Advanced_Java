<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" styleClass="root-pane" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="CarRentalController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Premium Car Rental" styleClass="header-text"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Customer Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" promptText="Enter name" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Car Model:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="modelField" promptText="e.g. Tesla Model 3" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Category:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="categoryBox" prefWidth="150" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Days:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Slider fx:id="daysSlider" min="1" max="30" showTickLabels="true" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <Button text="Calculate &amp; Book" onAction="#handleBooking" styleClass="action-button"/>
    
    <Separator/>
    
    <Label fx:id="resultLabel" styleClass="result-text" wrapText="true"/>
</VBox>